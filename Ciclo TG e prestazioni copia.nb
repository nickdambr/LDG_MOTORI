Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"cp", "[", 
     RowBox[{"\[Gamma]_", ",", "R_"}], "]"}], ":=", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"R", "/", 
      RowBox[{"(", 
       RowBox[{"\[Gamma]", "-", "1"}], ")"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "La", " ", "definsco", " ", "fuori", " ", "perch\[EAcute]", " ", "tanto", 
    " ", "lo", " ", "user\[OGrave]", " ", "sempre", " ", "in", " ", "ogni", 
    " ", "modulo"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"compressione", "[", 
   RowBox[{
   "Tin_", ",", "pin_", ",", "\[Beta]c_", ",", "\[Gamma]_", ",", "R_", ",", 
    "\[Eta]c_", ",", "sin_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "pout", ",", "Touts", ",", "souts", ",", "Tout", ",", "sout", ",", "Lc", 
      ",", "out"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pout", "=", 
      RowBox[{"\[Beta]c", "*", "pin"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Touts", "=", 
      RowBox[{"Tin", "*", 
       RowBox[{"\[Beta]c", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Gamma]", "-", "1"}], ")"}], "/", "\[Gamma]"}], 
         ")"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"souts", "=", " ", "sin"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Tout", "=", 
      RowBox[{"Tin", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Touts", "-", "Tin"}], ")"}], "/", "\[Eta]c"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sout", "=", 
      RowBox[{"sin", " ", "+", 
       RowBox[{
        RowBox[{"cp", "[", 
         RowBox[{"\[Gamma]", ",", "R"}], "]"}], "*", 
        RowBox[{"Log", "[", 
         RowBox[{"Tout", "/", "Touts"}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Lc", "=", 
      RowBox[{
       RowBox[{"cp", "[", 
        RowBox[{"\[Gamma]", ",", "R"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{"Tout", "-", "Tin"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"out", "=", 
      RowBox[{"{", 
       RowBox[{"Touts", ",", "Tout", ",", "souts", ",", "sout", ",", "Lc"}], 
       "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "out", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"espansione", "[", 
   RowBox[{
   "pin_", ",", "Tin_", ",", "\[Beta]c_", ",", "\[Gamma]_", ",", "R_", ",", 
    "\[Eta]e_", ",", "sin_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Touts", ",", "Tout", ",", "souts", ",", "sout", ",", "pout", ",", "Le", 
      ",", "out"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Touts", "=", 
      RowBox[{"Tin", "*", 
       RowBox[{"\[Beta]c", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"\[Gamma]", "-", "1"}], ")"}]}], "/", "\[Gamma]"}], 
         ")"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"souts", "=", " ", "sin"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Tout", "=", 
      RowBox[{"Tin", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Tin", "-", "Touts"}], ")"}], "*", "\[Eta]e"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sout", "=", 
      RowBox[{"sin", " ", "+", 
       RowBox[{
        RowBox[{"cp", "[", 
         RowBox[{"\[Gamma]", ",", "R"}], "]"}], "*", 
        RowBox[{"Log", "[", 
         RowBox[{"Tout", "/", "Touts"}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pout", "=", "pin"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Le", "=", 
      RowBox[{
       RowBox[{"cp", "[", 
        RowBox[{"\[Gamma]", ",", "R"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{"Tin", "-", "Tout"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"out", "=", 
      RowBox[{"{", 
       RowBox[{"Touts", ",", "Tout", ",", "souts", ",", "sout", ",", "Le"}], 
       "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "out", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"performance", "[", 
   RowBox[{
   "T3_", ",", "Tin_", ",", "Lc_", ",", "Le_", ",", "\[Gamma]_", ",", "R_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Qin", ",", "Lu", ",", "\[Eta]th", ",", "out"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Qin", "=", 
      RowBox[{
       RowBox[{"cp", "[", 
        RowBox[{"\[Gamma]", ",", "R"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{"T3", "-", "Tin"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Lu", "=", 
      RowBox[{"Le", "-", "Lc"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Eta]th", "=", 
      RowBox[{"Lu", "/", "Qin"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"out", "=", 
      RowBox[{"{", 
       RowBox[{"Lu", ",", "\[Eta]th"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "out", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{"calcTG", "[", 
   RowBox[{
   "T1_", ",", "p1_", ",", "\[Beta]c_", ",", "T3_", ",", "\[Gamma]_", ",", 
    "R_", ",", "\[Eta]c_", ",", "\[Eta]e_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "T2s", ",", "souts", ",", "sout", ",", "T2", ",", "Lc", ",", "T4", ",", 
      "Le", ",", "out"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"cp", "[", 
      RowBox[{"\[Gamma]", ",", "R"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"T2s", ",", "T2", ",", "s2s", ",", "s2", ",", "Lc"}], "}"}], 
      "=", 
      RowBox[{"compressione", "[", 
       RowBox[{
       "T1", ",", "p1", ",", "\[Beta]c", ",", "\[Gamma]", ",", "R", ",", 
        "\[Eta]c", ",", "s1"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"T4s", ",", "T4", ",", "s4s", ",", "s4", ",", "Le"}], "}"}], 
      "=", 
      RowBox[{"espansione", "[", 
       RowBox[{
       "p1", ",", "T3", ",", "\[Beta]c", ",", "\[Gamma]", ",", "R", ",", 
        "\[Eta]e", ",", "s3"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"out", "=", 
      RowBox[{"performance", "[", 
       RowBox[{
       "T3", ",", "T2", ",", "Lc", ",", "Le", ",", "\[Gamma]", ",", "R"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "out", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
